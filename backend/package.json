{
  "name": "assessment-creator-backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/workers/assessmentWorker.ts",
    "dev:all": "npx concurrently \"npm run dev\" \"npm run dev:worker\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/workers/assessmentWorker.js",
    "start:all": "npx concurrently \"npm run start\" \"npm run start:worker\""
  },
  "dependencies": {
    "bullmq": "^5.7.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "groq-sdk": "^0.12.0",
    "ioredis": "^5.3.2",
    "mongoose": "^8.3.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "uuid": "^9.0.1",
    "ws": "^8.17.0",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
